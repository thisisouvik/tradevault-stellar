# --- Supabase (Required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stellar / Soroban (Required for on-chain actions) ---
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_CONTRACT_ID=
STELLAR_PLATFORM_SECRET=
STELLAR_DEPLOYER_PUBLIC=
STELLAR_PLATFORM_PUBLIC=

# Public Stellar values (safe for frontend)
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_STELLAR_CONTRACT_ID=
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# --- Email (Optional: Resend free tier 100/day) ---
RESEND_API_KEY=
RESEND_FROM=TradeVault <noreply@tradevault.app>

# --- Tracking (Optional: TrackingMore free tier for carrier verification) ---
TRACKINGMORE_API_KEY=

# --- Cron Security (Required for scheduled tasks) ---
CRON_SECRET=your_random_secure_cron_secret
