
# --- Supabase (Required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stellar / Soroban (Required for on-chain actions) ---
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_CONTRACT_ID=
STELLAR_PLATFORM_SECRET=
STELLAR_USDC_ASSET=

# Relayer used by src/lib/stellar.ts for contract invocation
STELLAR_RELAYER_URL=
STELLAR_RELAYER_TOKEN=

# Optional webhook for reputation logging
STELLAR_REPUTATION_WEBHOOK_URL=

# Public Stellar values (safe for frontend)
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_STELLAR_CONTRACT_ID=

# --- Email (Optional: Resend free tier 100/day) ---
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=TrustEscrow <noreply@trustescrow.app>

# --- Tracking (Optional: TrackingMore free tier) ---
TRACKINGMORE_API_KEY=your_trackingmore_api_key

# --- Cron Security ---
CRON_SECRET=your_random_cron_secret_here
